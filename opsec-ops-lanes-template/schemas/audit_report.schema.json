{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Audit Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "audit_id",
    "network",
    "status",
    "coverage",
    "summary",
    "verified_claims",
    "inferred_claims",
    "limitations",
    "repo_commit",
    "generated_at"
  ],
  "properties": {
    "audit_id": {"type": "string"},
    "network": {
      "type": "string",
      "enum": ["devnet", "sepolia", "mainnet"]
    },
    "status": {
      "type": "string",
      "enum": ["pass", "pass_with_findings", "fail"]
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["covered", "total", "percent"],
      "properties": {
        "covered": {"type": "integer", "minimum": 0},
        "total": {"type": "integer", "minimum": 0},
        "percent": {"type": "number", "minimum": 0, "maximum": 100}
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["critical", "high", "medium", "low"],
      "properties": {
        "critical": {"type": "integer", "minimum": 0},
        "high": {"type": "integer", "minimum": 0},
        "medium": {"type": "integer", "minimum": 0},
        "low": {"type": "integer", "minimum": 0}
      }
    },
    "verified_claims": {
      "type": "array",
      "items": {"type": "string"}
    },
    "inferred_claims": {
      "type": "array",
      "items": {"type": "string"}
    },
    "limitations": {
      "type": "array",
      "items": {"type": "string"}
    },
    "repo_commit": {"type": "string"},
    "generated_at": {"type": "string"}
  }
}
