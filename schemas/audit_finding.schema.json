{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Audit Findings",
  "type": "object",
  "additionalProperties": false,
  "required": ["audit_id", "findings"],
  "properties": {
    "audit_id": {"type": "string"},
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "severity",
          "control_id",
          "title",
          "evidence_refs",
          "repro_commands",
          "status",
          "owner",
          "tier"
        ],
        "properties": {
          "id": {"type": "string"},
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "control_id": {"type": "string"},
          "title": {"type": "string"},
          "evidence_refs": {
            "type": "array",
            "items": {"type": "string"}
          },
          "repro_commands": {
            "type": "array",
            "items": {"type": "string"}
          },
          "status": {
            "type": "string",
            "enum": ["open", "accepted", "resolved"]
          },
          "owner": {"type": "string"},
          "tier": {
            "type": "string",
            "enum": ["VERIFIED", "INFERRED"]
          }
        }
      }
    }
  }
}
