{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://inshell.art/schemas/path-addresses.schema.json",
  "title": "PATH Frontend Addresses",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "path_nft",
    "path_minter",
    "path_minter_adapter",
    "pulse_auction",
    "treasury",
    "payment_token"
  ],
  "properties": {
    "path_nft": {"type": "string", "pattern": "^0x[a-fA-F0-9]{40}$"},
    "path_minter": {"type": "string", "pattern": "^0x[a-fA-F0-9]{40}$"},
    "path_minter_adapter": {"type": "string", "pattern": "^0x[a-fA-F0-9]{40}$"},
    "pulse_auction": {"type": "string", "pattern": "^0x[a-fA-F0-9]{40}$"},
    "treasury": {"type": "string", "pattern": "^0x[a-fA-F0-9]{40}$"},
    "payment_token": {"type": "string", "pattern": "^0x[a-fA-F0-9]{40}$"}
  }
}
