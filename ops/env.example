# Local-only env vars (do not commit secrets)
# Example public-safe placeholders:
# ETH_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/<API_KEY>
# SEPOLIA_DEPLOY_ADDRESS=0x1111111111111111111111111111111111111111
# SEPOLIA_DEPLOY_KEYSTORE_JSON=~/.opsec/sepolia/signers/deploy_sw_a/keystore.json               # deploy-only
# SEPOLIA_DEPLOY_KEYSTORE_PASSWORD_FILE=~/.opsec/sepolia/password-files/deploy_sw_a.password.txt # deploy-only
# MAINNET_DEPLOY_KEYSTORE_JSON=~/.opsec/mainnet/signers/deploy_sw_a/keystore.json               # deploy-only
# MAINNET_DEPLOY_KEYSTORE_PASSWORD_FILE=~/.opsec/mainnet/password-files/deploy_sw_a.password.txt # deploy-only
# ADMIN_LEDGER_ALIAS=SEPOLIA_ADMIN_HW_A
# TREASURY_LEDGER_ALIAS=SEPOLIA_TREASURY_HW_A
# LEDGER_HD_PATH=m/44'/60'/0'/0/0
# OPS_HOST_MARKER_FILE=~/.opsec/path/signing_os.marker
#
# Final ADMIN / TREASURY custody is Ledger-only.
# Do not model final mainnet/sepolia custody as keystore-based in this file.
