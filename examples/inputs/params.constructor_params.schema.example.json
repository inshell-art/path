  "title": "Example Constructor Params",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "name",
    "symbol",
    "paymentToken",
    "treasury"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "symbol": {
      "type": "string"
    },
    "paymentToken": {
      "type": "string"
    },
    "treasury": {
      "type": "string"
    }
  }
}
